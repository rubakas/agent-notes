{
  "name": "agent-notes",
  "version": "2.0.4",
  "description": "Multi-agent team with cost-optimized model routing. 18 specialized agents (lead/coder/reviewer/explorer/etc), 5 process discipline skills, and structured lead-delegate-review workflow for Claude Code.",
  "author": {
    "name": "Eugene Naumov"
  },
  "repository": "https://github.com/rubakas/agent-notes",
  "license": "MIT",
  "keywords": [
    "agents",
    "multi-agent",
    "cost-optimization",
    "workflow"
  ],
  "agents": "./.claude-plugin/agents/",
  "skills": "./.claude-plugin/skills/",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cat ~/.claude/agent-notes-context.md 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
