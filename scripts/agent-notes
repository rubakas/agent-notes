#!/usr/bin/env bash
set -e
SCRIPTS_DIR="$(cd "$(dirname "$0")" && pwd)"

case "${1:-help}" in
  install)    shift; exec bash "$SCRIPTS_DIR/install.sh" "$@" ;;
  uninstall)  shift; exec bash "$SCRIPTS_DIR/uninstall.sh" "$@" ;;
  update)     shift; exec bash "$SCRIPTS_DIR/update.sh" "$@" ;;
  doctor)     shift; exec bash "$SCRIPTS_DIR/doctor.sh" "$@" ;;
  info)       exec bash "$SCRIPTS_DIR/install.sh" --info ;;
  list)       shift; exec bash "$SCRIPTS_DIR/list.sh" "$@" ;;
  validate)   shift; exec bash "$SCRIPTS_DIR/validate.sh" "$@" ;;
  memory)     shift; exec bash "$SCRIPTS_DIR/memory.sh" "$@" ;;
  help|--help|-h)
    cat <<'EOF'
agent-notes — AI agent configuration manager

Usage: agent-notes <command> [options]

Commands:
  install [--local] [--copy]    Build and install components (global by default)
  uninstall [--local]           Remove installed components
  update                        Pull latest changes, rebuild, and reinstall
  doctor [--local] [--fix]      Check installation health, optionally fix issues
  info                          Show installation status and component counts
  list [agents|skills|rules]    List installed components
  validate                      Lint source configuration files
  memory [options]              Manage agent memory

Options:
  --local     Target current project instead of global (~/)
  --copy      Copy files instead of symlink (with --local only)
  --fix       Auto-fix found issues (with doctor only)

Examples:
  agent-notes install                Install globally (symlinks)
  agent-notes install --local        Install to current project (symlinks)
  agent-notes install --local --copy Install to current project (copies)
  agent-notes uninstall              Remove global installation
  agent-notes uninstall --local      Remove local installation
  agent-notes update                 Update to latest version
  agent-notes doctor                 Check global health
  agent-notes doctor --local         Check local health
  agent-notes doctor --fix           Check and fix global issues
  agent-notes doctor --local --fix   Check and fix local issues
  agent-notes list agents            List installed agents
  agent-notes info                   Show status

Setup:
  ln -sf $(pwd)/scripts/agent-notes /usr/local/bin/agent-notes
EOF
    ;;
  *)
    echo "Unknown command: $1"
    echo "Run 'agent-notes help' for usage."
    exit 1
    ;;
esac
