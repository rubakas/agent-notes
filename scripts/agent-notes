#!/usr/bin/env bash
#
# agent-notes — CLI wrapper for agent-notes management scripts.
#
# Usage: agent-notes <command> [args...]
#
set -e

MY_SCRIPT=$0
if [[ -L "$MY_SCRIPT" ]]; then
  MY_SCRIPT="$(readlink "$MY_SCRIPT")"
fi
SCRIPTS_DIR="$(cd "$(dirname "$MY_SCRIPT")" && pwd)"

echo "Running agent-notes from: $MY_SCRIPT"

case "${1:-help}" in
  install)    shift; exec bash "$SCRIPTS_DIR/install.sh" "$@" ;;
  uninstall)  shift; exec bash "$SCRIPTS_DIR/uninstall.sh" "$@" ;;
  validate)   shift; exec bash "$SCRIPTS_DIR/validate.sh" "$@" ;;
  memory)     shift; exec bash "$SCRIPTS_DIR/memory.sh" "$@" ;;
  check)      exec bash "$SCRIPTS_DIR/install.sh" --check ;;
  info)       exec bash "$SCRIPTS_DIR/install.sh" --info ;;
  help|--help|-h)
    cat <<'EOF'
Usage: agent-notes <command> [args...]

Commands:
  install <what> <where> [--copy]   Install components
  uninstall <what> <where>          Remove installed components
  validate                          Lint all configs in the repo
  memory [opts]                     Manage agent memory
  check                             Validate existing symlinks
  info                              Show component counts and status
  help                              Show this help

Install arguments:
  <what>    all | skills | agents | rules
  <where>   global | local
  --copy    Copy files instead of symlink (local only)

Memory options:
  --list             List all memories (default)
  --size             Total disk usage
  --show <name>      View one agent's memory
  --reset [name]     Clear memory (all or one agent)
  --export           Back up to agent-notes/memory-backup/
  --import           Restore from backup

Examples:
  agent-notes install all global
  agent-notes install agents local --copy
  agent-notes uninstall all global
  agent-notes validate
  agent-notes memory --show coder
  agent-notes check
  agent-notes info

Make globally available:
  ln -sf ~/agent-notes/scripts/agent-notes /usr/local/bin/agent-notes
EOF
    ;;
  *)
    echo "Unknown command: $1"
    echo "Run 'agent-notes help' for usage."
    exit 1
    ;;
esac
