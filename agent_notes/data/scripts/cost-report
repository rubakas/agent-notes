#!/usr/bin/env python3
"""Auto-detect CLI and delegate to the appropriate cost-report script."""
import subprocess
import sys
from pathlib import Path

scripts_dir = Path(__file__).parent
opencode_db = Path.home() / ".local" / "share" / "opencode" / "opencode.db"

if opencode_db.exists():
    script = scripts_dir / "cost-report-opencode"
else:
    script = scripts_dir / "cost-report-claude"

sys.exit(subprocess.run([sys.executable, str(script)]).returncode)
